# GramScout Configuration

# Database
POSTGRES_USER=gramscout
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gramscout
DATABASE_URL=postgresql+asyncpg://gramscout:changeme@postgres:5432/gramscout

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram API (get from https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# OpenRouter (for AI comment generation)
OPENROUTER_API_KEY=

# App
SECRET_KEY=change-this-to-a-random-string
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Encryption (for session strings)
ENCRYPTION_KEY=
